# ===== 数据库 (MySQL) =====
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your-mysql-password
DATABASE_NAME=news_agent

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ===== LLM APIs =====
# OpenAI 兼容接口（支持 DeepSeek、OpenRouter、OpenAI 等）
LLM_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxxxxxxxxxxx
LLM_MODEL=gpt-4o
# 限频降级备用模型（同一 API 端点，仅切换模型名）
LLM_FALLBACK_MODEL=gpt-4o-mini
# 每分钟最大 LLM 请求数（主动限速，防止触发 API 限频；-1 禁用限流）
LLM_RPM=10
# 限频告警邮箱（收到 API 限频时发送告警通知）
ALERT_EMAIL=

# ===== 采集服务 =====
# 微信公众号采集（从微信公众号后台手动获取 Token 和 Cookie）
WECHAT_TOKEN=
WECHAT_COOKIE=
WECHAT_MAX_AGE_DAYS=7
# 微信公众号采集（第三方服务 WeRSS）
WERSS_API_KEY=
# GitHub Personal Access Token
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# 测试模式：每种类型最多采集的源数量（不设或 0 表示不限制）
COLLECT_MAX_SOURCES=

# ===== 推送服务 =====
# Telegram Bot（可选）
TELEGRAM_BOT_TOKEN=
# 邮件 SMTP（用于邮件推送 + 验证码发送）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password-or-app-key
SMTP_FROM=News Agent <your-email@example.com>

# ===== 安全 =====
# JWT 签名密钥（建议使用 32 位以上随机字符串）
JWT_SECRET=your-jwt-secret-change-me

# ===== 调试 =====
# 开启 Skill 脚本调试模式（脚本 stdout 输出到控制台）
# SKILL_DEBUG=true
# TypeORM 日志级别（true / false / error,warn,query）
# TYPEORM_LOGGING=error,warn
